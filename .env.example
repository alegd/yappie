# Database
DATABASE_URL=postgresql://yappie:yappie_dev@localhost:5432/yappie

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3001
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001

# OpenAI (required for audio pipeline)
OPENAI_API_KEY=sk-your-key-here

# Jira OAuth (required for Jira integration)
JIRA_CLIENT_ID=your-client-id
JIRA_CLIENT_SECRET=your-client-secret
JIRA_CALLBACK_URL=http://localhost:3001/api/integrations/jira/callback

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
