AUTH_SECRET=generate-with-openssl-rand-base64-32

NEXT_PUBLIC_API_URL=http://localhost:3001

NEXT_PUBLIC_HOST_URL=http://localhost:3000

NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_SAMPLE_RATE=1.0
# ─── Umami analytics (optional) ──────────────────────────
# Both must be set to enable the script. Leaving them empty
# skips analytics entirely — good for self-hosted deployments.
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
