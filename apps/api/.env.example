# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=54320
DB_USER=yappie
DB_PASSWORD=yappie_dev
DB_NAME=yappie

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (JWT) ──────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── AI Models ───────────────────────────────────────────
AI_TRANSCRIPTION_MODEL=whisper-1
AI_DECOMPOSITION_MODEL=gpt-4o-mini
AI_GENERATION_MODEL=gpt-4o-mini

# ─── Storage ─────────────────────────────────────────────
UPLOAD_PATH=./uploads

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Jira OAuth (optional) ──────────────────────────────
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_CALLBACK_URL=http://localhost:3001/api/v1/integrations/jira/callback

# ─── Quotas ──────────────────────────────────────────────
QUOTA_FREE_MINUTES=30
QUOTA_PRO_MINUTES=300

ENCRYPTION_KEY=
SENTRY_DSN=

# ─── Sentry (Web) — sample rates between 0 and 1 ────────
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.0
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_SAMPLE_RATE=1.0
